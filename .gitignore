/target
/Cargo.lock.bak
**/*.rs.bk
.DS_Store
*.swp
*.tmp
.idea/
.vscode/
*.profraw
lcov.info
/coverage/

# pmat / pv local caches — regenerated by tools, not source.
.pmat/
.pv/
**/.pv/

# Local Qdrant storage from `make up` (named volume keeps the real
# data in Docker; this dir only matters if a future bind-mount is
# added).
/qdrant_storage/

# Local-only film corpus override — committed corpus is
# data/films.json; data/films.local.json is the user's swap-in.
data/films.local.json

# Aprender models stash — never check in *.apr binaries.
*.apr
models/
